# ─────────────────────────────────────────────────────────────────────────────
# Mnemosyne environment. Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database (matches docker-compose.yml defaults) -------------------------
POSTGRES_USER=mnemosyne
POSTGRES_PASSWORD=mnemosyne
POSTGRES_DB=mnemosyne
POSTGRES_PORT=5432
# Connection string used by the app, the worker, the MCP server and migrations.
DATABASE_URL=postgres://mnemosyne:mnemosyne@localhost:5432/mnemosyne

# --- Single-user auth -------------------------------------------------------
# The owner password. Also the input to the argon2-derived key that encrypts
# private-node bodies at rest, so changing it makes old private bodies unreadable.
MNEMOSYNE_PASSWORD=change-me-to-a-long-passphrase
# 32+ char secret for iron-session cookie sealing.
SESSION_SECRET=change-me-this-must-be-at-least-32-characters-long

# --- Embeddings ------------------------------------------------------------
# Embeddings run locally via transformers.js (all-MiniLM-L6-v2, 384-dim) — no key,
# free, offline. The model (~90MB) downloads once on first use, then is cached.

# --- LLM (OpenRouter, OpenAI-compatible) ------------------------------------
# Create a key at https://openrouter.ai/keys. Any model id from openrouter.ai/models works.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL is a comma-separated FALLBACK CHAIN (primary first). If a model is rate-limited
# (429) or down, the next is tried automatically — this is what keeps Mnemosyne free + working.
# Default = fast sparse-MoE models (Nemotron Super is ~0.4s; Ultra is 5 MIN, avoid it).
# Browse free models: https://openrouter.ai/models?q=free
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-nano-30b-a3b:free,google/gemma-4-31b-it:free
# Optional separate chain for deep synthesis; falls back to LLM_MODEL when blank.
LLM_MODEL_DEEP=
# Fully-private / no-limits alternative: run a local model via Ollama and point at it —
#   OPENROUTER_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen2.5:14b   (then `ollama pull qwen2.5:14b`)

# --- App --------------------------------------------------------------------
# Public base URL (used by PWA share-target + MCP HTTP config snippets).
APP_URL=http://localhost:3000
# Port for the standalone MCP HTTP/SSE transport (stdio needs no port).
MCP_HTTP_PORT=8848
